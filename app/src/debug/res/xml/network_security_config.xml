<?xml version="1.0" encoding="utf-8"?>
<!--
Network Security Configuration for Debug Builds

Allows cleartext HTTP for emulator testing (10.0.2.2).

The Android emulator uses the special IP 10.0.2.2 to refer to the host machine.
For E2E testing, we need to allow HTTP (cleartext) connections to the any-sync
infrastructure running on the host:
- Coordinator: http://10.0.2.2:1004
- Filenode: http://10.0.2.2:1005

This configuration is ONLY used for debug builds and should NEVER be used
in production releases.
-->
<network-security-config>
    <!-- Allow cleartext traffic for emulator's host IP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>

    <!-- For all other domains, require HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
